# blenderserver configuration

# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=8060

# Claude API (optional — only needed for text prompt → render intent conversion)
# Not required if using scene presets directly.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxx
ANTHROPIC_MODEL=claude-sonnet-4-6

# Database (SQLite path)
DB_PATH=./data/blenderserver.db

# Queue backend: memory | redis
QUEUE_BACKEND=memory
# REDIS_URL=redis://localhost:6379/0

# Worker callback authentication
WORKER_CALLBACK_SECRET=change-this-in-production

# CORS
CORS_ORIGINS=*

# Asset storage directories
UPLOAD_DIR=./uploads
OUTPUT_DIR=./outputs
